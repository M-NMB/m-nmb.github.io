{%- comment -%}
  Add compact journal details that are present in BibTeX but omitted by the
  default al-folio bibliography line.
{%- endcomment -%}
{%- assign publication_details = '' -%}

{%- if entry.volume -%}
  {%- capture volume_part -%}<strong>{{ entry.volume }}</strong>{%- if entry.number -%}({{ entry.number }}){%- endif -%}{%- endcapture -%}
  {%- assign publication_details = volume_part -%}
{%- elsif entry.number -%}
  {%- capture number_part -%}no. {{ entry.number }}{%- endcapture -%}
  {%- assign publication_details = number_part -%}
{%- endif -%}

{%- if entry.pages -%}
  {%- assign page_range = entry.pages | replace: '--', '&ndash;' -%}
  {%- if publication_details != '' -%}
    {%- capture publication_details -%}{{ publication_details }}, {{ page_range }}{%- endcapture -%}
  {%- else -%}
    {%- assign publication_details = page_range -%}
  {%- endif -%}
{%- elsif entry.article_number -%}
  {%- if publication_details != '' -%}
    {%- capture publication_details -%}{{ publication_details }}, {{ entry.article_number }}{%- endcapture -%}
  {%- else -%}
    {%- assign publication_details = entry.article_number -%}
  {%- endif -%}
{%- endif -%}

{%- if entry.year -%}
  {%- capture year_part -%}({{ entry.year }}){%- endcapture -%}
  {%- if publication_details != '' -%}
    {%- capture publication_details -%}{{ publication_details }} {{ year_part }}{%- endcapture -%}
  {%- else -%}
    {%- assign publication_details = year_part -%}
  {%- endif -%}
{%- endif -%}

{%- if publication_details != '' -%}
  {%- capture entrytype -%}{{ entrytype }} {{ publication_details }}{%- endcapture -%}
  {%- assign entrymonth = '' -%}
  {%- assign entryyear = '' -%}
{%- endif -%}
